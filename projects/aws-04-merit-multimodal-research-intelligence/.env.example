# MERIT local development configuration
# DO NOT place secrets in this file.

AWS_REGION=us-east-1
MERIT_ENVIRONMENT=dev
LOG_LEVEL=INFO

# These will be populated when AWS infrastructure exists.
UPLOAD_BUCKET=
PROCESSED_BUCKET=
DOCUMENT_TABLE=
VECTOR_INDEX=

# Model configuration will later be stored in AWS SSM Parameter Store.
EMBEDDING_MODEL_ID=
GENERATION_MODEL_ID=

# Retrieval defaults
RETRIEVAL_CANDIDATE_K=12
RERANK_TOP_K=5
